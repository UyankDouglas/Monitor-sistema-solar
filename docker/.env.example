# Copie para .env e ajuste conforme necessário.
# Banco de dados (TimescaleDB / PostgreSQL)
POSTGRES_DB=solar
POSTGRES_USER=solar
POSTGRES_PASSWORD=solar
POSTGRES_PORT=5432

# pgAdmin (o e-mail precisa ter TLD válido — ".local" é rejeitado)
PGADMIN_EMAIL=admin@solar.dev
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# Portas expostas
BACKEND_PORT=8080
FRONTEND_PORT=5173
